# ============================================================
# plae — environment variables template
# Copy this file:
#   - apps/web/.env.local   (only VITE_* keys are exposed to the browser)
#   - apps/api/.dev.vars    (Wrangler dev — server-side only)
# Production secrets for Workers must be set with `wrangler secret put`.
# ============================================================

# ---- Frontend (apps/web) — public, exposed to browser ------
VITE_API_BASE_URL=http://localhost:8787
VITE_GOOGLE_OAUTH_CLIENT_ID=

# ---- Backend (apps/api) — server-side only -----------------
ANTHROPIC_API_KEY=
HF_ENDPOINT_URL=
HF_TOKEN=
GOOGLE_OAUTH_CLIENT_ID=
ALLOWED_EMAIL_DOMAIN=
STRUDEL_DAILY_QUOTA=30
MUSICGEN_DAILY_QUOTA=10
