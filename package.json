{
  "name": "plae",
  "version": "0.0.0",
  "private": true,
  "description": "Prompt-Layered Audio Engine — AI music creation web app for middle school students",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @plae/web dev",
    "dev:api": "pnpm --filter @plae/api dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "typescript": "5.5.4"
  }
}
